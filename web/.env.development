# npm run dev 时自动加载
# 本机前端: http://localhost:5173
# 地图数据代理到 Magic Flower 服上的 squaremap 插件 HTTP 服务
MAP_SERVER_URL=http://magicflower.org:25566

# Vite 代理 → 远程服：限制并发连接，避免 ETIMEDOUT
PROXY_MAX_SOCKETS=3
PROXY_TIMEOUT_MS=60000

# 浏览器 → 远程瓦片：限制同时 fetch 的 PNG 数量
VITE_MAP_TILE_CONCURRENCY=3

# 主循环间隔（毫秒）。原默认 1000；改为 3000 可降低 JSON/瓦片刷新频率
VITE_MAP_TICK_MS=3000
