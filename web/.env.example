# Vite 会把 /tiles、/images 等请求代理到这个地址
MAP_SERVER_URL=http://magicflower.org:25566

# --- 开发环境调优（写入 .env.development 即可，见仓库内默认配置）---
# PROXY_MAX_SOCKETS=3          # Vite 代理到远程服的最大并发连接数
# PROXY_TIMEOUT_MS=60000       # 代理超时（毫秒）
# VITE_MAP_TILE_CONCURRENCY=3  # 浏览器同时请求的 PNG 瓦片数上限
# VITE_MAP_TICK_MS=3000        # 玩家/标记/瓦片刷新主循环间隔（毫秒，默认 1000）
