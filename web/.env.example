# Vite 会把 /tiles、/images 等请求代理到这个地址
#
# 常见两种开发方式（二选一）:
#
# 1) 本机前端 + 远程 Magic Flower 服数据（推荐，已写在 .env.development）
#    MAP_SERVER_URL=http://magicflower.org:25566
#
# 2) 本机前端 + 本机 MC 测试服数据（squaremap 默认 HTTP 端口为 8080）
#    MAP_SERVER_URL=http://localhost:8080
#
# Magic Flower 服上 squaremap 插件监听 25566；本机 dev 页面固定为 http://localhost:5173

MAP_SERVER_URL=http://magicflower.org:25566
